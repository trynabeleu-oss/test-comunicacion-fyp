var LNAMES = {
  AS: "Comunicación asertiva",
  PA: "Comunicación pasiva",
  AG: "Comunicación agresiva",
  PAG: "Comunicación pasivo-agresiva",
  EV: "Comunicación evitativa"
};

var cur = 0, ans = new Array(16).fill(null);
var TOTAL = 16;

function startTest() {
  document.getElementById('cover').classList.add('hidden');
  document.getElementById('test').classList.remove('hidden');
  renderQ();
}

function renderQ() {
  var q = QS[cur];
  var pct = Math.round((cur / TOTAL) * 100);
  document.getElementById('prog').style.width = pct + '%';
  document.getElementById('prog-lbl').textContent = 'Pregunta ' + (cur + 1) + ' de ' + TOTAL;
  document.getElementById('prog-pct').textContent = pct + '%';
  document.getElementById('btn-prev').disabled = cur === 0;
  document.getElementById('btn-next').disabled = ans[cur] === null;
  document.getElementById('btn-next').textContent = cur === TOTAL - 1 ? 'Ver mi resultado →' : 'Siguiente →';

  var ltrs = ['A', 'B', 'C', 'D', 'E'];
  var h = '<div class="q-card"><div class="q-num">Situación ' + (cur + 1) + '</div>';
  h += '<div class="q-text">' + q.t + '</div>';
  q.o.forEach(function(o, i) {
    h += '<div class="opt' + (ans[cur] === i ? ' sel' : '') + '" onclick="pick(' + i + ')">';
    h += '<div class="opt-ltr">' + ltrs[i] + '</div>';
    h += '<div class="opt-txt">' + o.t + '</div>';
    h += '</div>';
  });
  h += '</div>';
  document.getElementById('q-container').innerHTML = h;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function pick(i) { ans[cur] = i; renderQ(); }
function prevQ() { if (cur > 0) { cur--; renderQ(); } }
function nextQ() {
  if (ans[cur] === null) return;
  if (cur < TOTAL - 1) { cur++; renderQ(); }
  else showResult();
}

function showResult() {
  var sc = { AS: 0, PA: 0, AG: 0, PAG: 0, EV: 0 };
  QS.forEach(function(q, qi) {
    if (ans[qi] !== null) sc[q.o[ans[qi]].l]++;
  });

  var order = ['AS', 'PA', 'AG', 'PAG', 'EV'];
  var sorted = order.slice().sort(function(a, b) { return sc[b] - sc[a]; });
  var top = sorted[0];
  var maxS = sc[top];
  var tied = sorted.filter(function(l) { return sc[l] === maxS; });
  var r = RES[top];

  document.getElementById('test').classList.add('hidden');
  var rs = document.getElementById('results');
  rs.classList.remove('hidden');

  var h = '';

  // Hero
  h += '<div class="res-hero">';
  h += '<div class="res-hero-art"><div class="bubble b1"></div><div class="bubble b2"></div></div>';
  h += '<div class="res-hero-inner">';
  h += '<div class="res-from">Feliz y en Pareja · Escuela del amor</div>';
  h += '<div class="res-icon-ring" style="background:' + r.color + '22">' + r.icon + '</div>';
  h += '<div class="res-label">Tu estilo de comunicación</div>';
  h += '<div class="res-name" style="color:' + r.color + '">' + r.name + '</div>';
  h += '<div class="res-tagline">Así es como aprendiste a decir, callar o reaccionar en pareja.</div>';
  h += '</div></div>';

  // Scores
  h += '<div class="scores">';
  sorted.forEach(function(l) {
    var pct = Math.round((sc[l] / TOTAL) * 100);
    h += '<div class="sc-row' + (l === top ? ' top' : '') + '">';
    h += '<div class="sc-lbl">' + LNAMES[l] + '</div>';
    h += '<div class="sc-track"><div class="sc-fill" style="width:' + pct + '%"></div></div>';
    h += '<div class="sc-val">' + sc[l] + '</div>';
    h += '</div>';
  });
  h += '</div>';

  // Tie box
  if (tied.length > 1) {
    h += '<div class="tie-box"><p>Tenés empate entre <strong>' + tied.map(function(l) { return LNAMES[l]; }).join(' y ') + '</strong>. Eso significa que usás ambos estilos según el contexto o el estado emocional en que estés. Ninguno cancela al otro — los dos son parte de cómo te comunicás hoy.</p></div>';
  }

  // Main result card
  h += '<div class="r-card">';
  h += '<div class="r-card-head">';
  h += '<div class="r-card-icon" style="background:' + r.bg + '">' + r.icon + '</div>';
  h += '<div class="r-card-title">' + r.name + '</div>';
  h += '</div>';
  h += '<div class="r-badge r-badge-main">Tu estilo principal</div>';
  h += '<p>' + r.desc + '</p>';
  h += '<div class="r-div"></div>';
  h += '<p><strong>Cómo se ve en tu relación:</strong> ' + r.enRel + '</p>';
  h += '<div class="r-div"></div>';

  h += '<div class="tip-row"><div class="tip-dot"></div><div class="tip-txt"><strong>Error frecuente:</strong> ' + r.error + '</div></div>';
  h += '<div class="tip-row"><div class="tip-dot"></div><div class="tip-txt"><strong>Qué trabajar:</strong> ' + r.tip + '</div></div>';
  h += '</div>';

  // Second result card
  if (sorted.length > 1 && sc[sorted[1]] > 0 && sorted[1] !== top) {
    var r2 = RES[sorted[1]];
    h += '<div class="r-card">';
    h += '<div class="r-card-head">';
    h += '<div class="r-card-icon" style="background:' + r2.bg + '">' + r2.icon + '</div>';
    h += '<div class="r-card-title">' + r2.name + '</div>';
    h += '</div>';
    h += '<div class="r-badge r-badge-sec">Tu segundo estilo</div>';
    h += '<p>' + r2.desc + '</p>';
    h += '<div class="r-div"></div>';
    h += '<div class="tip-row"><div class="tip-dot"></div><div class="tip-txt"><strong>Qué trabajar:</strong> ' + r2.tip + '</div></div>';
    h += '</div>';
  }

  // Reflection
  h += '<div class="reflection">';
  h += '<div class="refl-art"><div class="bubble b1"></div></div>';
  h += '<div class="refl-inner">';
  h += '<div class="refl-eyebrow">Para cerrar</div>';
  h += '<div class="refl-quote">"La forma en que te comunicás no es tu personalidad… es lo que aprendiste sobre qué pasa cuando decís lo que sentís. Y eso, a diferencia de lo que creés, sí se puede cambiar."</div>';
  h += '<div class="refl-credit">— Feliz y en Pareja · Escuela del amor</div>';
  h += '</div></div>';

  h += '<div class="res-footer">';
  h += '<p>Compartí este test con tu pareja y comparen sus estilos</p>';
  h += '<button class="btn-restart" onclick="restartAll()">Hacer el test de nuevo</button>';
  h += '</div>';

  rs.innerHTML = h;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function restartAll() {
  cur = 0;
  ans = new Array(TOTAL).fill(null);
  document.getElementById('results').classList.add('hidden');
  document.getElementById('test').classList.add('hidden');
  document.getElementById('cover').classList.remove('hidden');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
</body>
</html>
