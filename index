  }
];

var RES = {
  AS: {
    name: "Comunicación asertiva",
    icon: "🗣️",
    color: "#0e7a65",
    bg: "#e6f7f3",
    desc: "Decís lo que pensás y sentís, sin atacar ni callarte. No es que no tengas conflictos — es que los manejás de frente, con respeto, buscando que ambos salgan bien.",
